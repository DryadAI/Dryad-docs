{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DryadAI/dryad-docs/schemas/promotion-proposal.schema.json",
  "title": "Memory Promotion Proposal (Curator → Cowork)",
  "description": "Proposal from Curator to promote facts/skills to semantic/procedural store",
  "type": "object",
  "required": ["proposal_id", "timestamp", "type", "candidates", "confidence", "source_traces"],
  "properties": {
    "proposal_id": {"type": "string"},
    "timestamp": {"type": "string", "format": "date-time"},
    "type": {"type": "string", "enum": ["fact", "skill", "policy"]},
    "candidates": {
      "type": "array",
      "items": {"type": "object"}
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "source_traces": {
      "type": "array",
      "items": {"type": "string", "description": "trace_id list"}
    },
    "contradictions": {
      "type": "array",
      "items": {"type": "object"}
    },
    "auto_approve_eligible": {"type": "boolean"}
  }
}
